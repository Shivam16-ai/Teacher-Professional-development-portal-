# Production Environment Configuration Template
# Copy this file and configure for your production environment

# Server Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (MySQL)
# Update these with your production database credentials
DB_HOST=your-production-db-host.com
DB_PORT=3306
DB_USER=your_production_user
DB_PASSWORD=your_strong_production_password
DB_NAME=teacher_platform_prod

# JWT Configuration
# IMPORTANT: Generate a strong secret key for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-a-strong-random-secret-min-64-characters-use-crypto
JWT_EXPIRE=7d

# CORS Configuration
# Update to your production frontend URL
CORS_ORIGIN=https://your-production-frontend.vercel.app

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting (adjust based on expected traffic)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Email Configuration (Optional - for future features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Redis Configuration (Optional - for caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# AWS S3 (Optional - for file storage)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=teacher-platform-uploads

# Monitoring (Optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx
